{
  "name": "ASCON SCA Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-contrib/features/arm-cross-toolchain:1": {}
  },
  "postCreateCommand": "pip install tensorflow numpy h5py scikit-learn matplotlib pandas pyyaml",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.cpptools"
      ]
    }
  }
}
